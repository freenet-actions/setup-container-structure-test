{
  "name": "setup-container-structure-test",
  "version": "5.0.1",
  "private": true,
  "description": "Setup the container-structure-test tools",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build",
    "test": "jest",
    "all": "npm run build && npm run format && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freenet-actions/container-structure-test.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "2.0.1",
    "@actions/tool-cache": "3.0.1"
  },
  "devDependencies": {
    "@actions/io": "2.0.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@typescript-eslint/parser": "8.58.2",
    "@vercel/ncc": "0.38.4",
    "eslint": "9.39.4",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-jest": "29.15.2",
    "globals": "17.5.0",
    "jest": "30.3.0",
    "jest-circus": "30.3.0",
    "prettier": "3.8.2",
    "ts-jest": "29.4.9",
    "typescript": "5.9.2"
  }
}
